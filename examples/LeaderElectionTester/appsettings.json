{
  "LeaderElectionType": "Redis", // default leader election mechanism to use. Can be overridden via command line or environment variable.

  "Logging": {
    "LogLevel": {
      "Default": "Information",
      // "LeaderElectionTester": "Warning", // reduce noise from the example app itself
      // "LeaderElection": "Debug", // to see more details about the leader election process
      "Microsoft": "Warning",
      "Microsoft.Hosting.Lifetime": "Information",
      "Azure": "Error",
      "ZiggyCreatures": "Warning",
      "Npgsql": "Warning"
    },
    "Console": {
      "FormatterName": "simple",
      "FormatterOptions": {
        "SingleLine": true,
        "TimestampFormat": "HH:mm:ss "
      }
    }
  }
}
