<Project>
  <!-- See https://aka.ms/dotnet/msbuild/customize for more details on customizing your build -->

  <!-- Repository properties -->
  <PropertyGroup>
    <Product>LeaderElection</Product>
    <Description>An easy-to-use C# implementation of the distributed leader election pattern, leveraging common infrastructure tools like Azure Blob Storage, Redis, and others.</Description>
    <Authors>Greg James</Authors>
    <Copyright>Copyright 2025 Greg James</Copyright>
    <RepositoryUrl>https://github.com/gregyjames/LeaderElection</RepositoryUrl>
    <RepositoryType>git</RepositoryType>

    <!-- Folders -->
    <RepoRoot>$([MSBuild]::EnsureTrailingSlash('$(MSBuildThisFileDirectory)'))</RepoRoot>
    <SrcDir>$(RepoRoot)</SrcDir>
    <TestsDir>$(RepoRoot)</TestsDir>
    <ExamplesDir>$(RepoRoot)</ExamplesDir>
    <!-- TODO: Split src, test, and example projects into separate directories 
         (./src, ./tests, ./examples), each with their own Directory.Build.props -->
  </PropertyGroup>

  <!-- Build settings -->
  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <IsPackable>false</IsPackable>
    <!-- TODO: Turn on maximum static analysis in all builds -->
  </PropertyGroup>

  <!-- Generate deterministic build when running in CI environments -->
  <PropertyGroup Condition="'$(GITHUB_ACTIONS)' == 'true' or '$(CI)' == '1'">
    <ContinuousIntegrationBuild Condition="'$(ContinuousIntegrationBuild)' == ''">true</ContinuousIntegrationBuild>
  </PropertyGroup>

  <!-- Nuget package properties https://docs.microsoft.com/en-us/nuget/reference/msbuild-targets -->
  <PropertyGroup>
    <PackageId>$(MSBuildProjectName)</PackageId>
    <Title>$(MSBuildProjectName)</Title>
    <PackageTags>LeaderElection;Leader;Election;Leadership;Distributed;Coordination;Kubernetes;Azure;AWS</PackageTags>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <PackageLicenseFile>LICENSE.md</PackageLicenseFile>
    <PackageIcon>icon.png</PackageIcon>
    <PackageIconUrl>$(RepositoryUrl)/blob/main/icon.png?raw=true</PackageIconUrl>
    <PackageProjectUrl>$(RepositoryUrl)</PackageProjectUrl>
    <PackageReleaseNotes>$(RepositoryUrl)/releases</PackageReleaseNotes>
    <!-- SourceLink: Will generate a separate .snupkg file containing the PDB. -->
    <!-- It will be published along with the main package. -->
    <PublishRepositoryUrl>true</PublishRepositoryUrl>
    <IncludeSymbols>true</IncludeSymbols>
    <SymbolPackageFormat>snupkg</SymbolPackageFormat>
  </PropertyGroup>
  <ItemGroup>
    <!-- Include license, icon, and readme files in the package -->
    <None Include="$(RepoRoot)$(PackageLicenseFile)" Pack="true" PackagePath="" />
    <None Include="$(RepoRoot)$(PackageIcon)" Pack="true" PackagePath="" />
    <None
      Condition="Exists('$(MSBuildProjectDirectory)/$(PackageReadmeFile)')"
      Include="$(MSBuildProjectDirectory)/$(PackageReadmeFile)"
      Pack="true"
      PackagePath=""
    />
  </ItemGroup>
</Project>
